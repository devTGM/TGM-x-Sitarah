      "blocks": {
        "text_JgGCta": {
          "type": "text",
          "settings": {
            "text": "<p><em>At Sitarah, we blend tradition with modern elegance to bring you contemporary suits that celebrate India’s rich textile heritage. Specializing in stylish suit sets crafted with intricate laces and delicate embroideries, our designs offer a perfect fusion of timeless craftsmanship and modern aesthetics.<br/><br/>Each piece is thoughtfully designed to be versatile, so whether you're attending a festive event or looking for something chic yet comfortable for everyday wear, Sitarah has you covered. Our goal is to make high-quality, beautifully crafted Indian wear accessible to everyone, without compromising on style or affordability.<br/><br/>Explore our collection, and discover outfits that reflect both your cultural roots and modern sensibilities.</em></p>",
            "text_style": "body"
          }
        }
      },
