{% comment %}
  Renders custom cart drawer matching luxury reference design
  Usage:
  {% render 'cart-drawer' %}
{% comment %}

{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-cart-drawer.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

<style>
  .drawer {
    visibility: hidden;
  }
</style>

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>
    <div
      class="drawer__inner gradient color-{{ settings.cart_color_scheme }}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sections.cart.title' | t }}"
      tabindex="-1"
    >
      {%- if cart == empty -%}
        <div class="drawer__inner-empty">
          <div class="cart-drawer__warnings center{% if settings.cart_drawer_collection != blank %} cart-drawer__warnings--has-collection{% endif %}">
            <div class="cart-drawer__empty-content">
              <h2 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h2>
              <button
                class="drawer__close"
                type="button"
                onclick="this.closest('cart-drawer').close()"
                aria-label="{{ 'accessibility.close' | t }}"
              >
                {% render 'icon-close' %}
              </button>
              <a href="{{ routes.all_products_collection_url }}" class="button">
                {{ 'general.continue_shopping' | t }}
              </a>

              {%- if shop.customer_accounts_enabled and customer == null -%}
                <p class="cart__login-title h3">{{ 'sections.cart.login.title' | t }}</p>
                <p class="cart__login-paragraph">
                  {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
                </p>
              {%- endif -%}
            </div>
          </div>
          {%- if settings.cart_drawer_collection != blank -%}
            <div class="cart-drawer__collection">
              {% render 'card-collection', card_collection: settings.cart_drawer_collection, columns: 1 %}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="drawer__header">
        <h2 class="drawer__heading">{{ 'sections.cart.title' | t }}</h2>
        <button
          class="drawer__close"
          type="button"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          {% render 'icon-close' %}
        </button>
      </div>

      {%- if cart != empty -%}
        <!-- Top Shipping Bar -->
        {%- assign free_shipping_threshold = 499900 -%}
        {%- assign cart_subtotal = cart.total_price -%}
        <div class="cart-drawer__top-shipping">
          <div class="cart-drawer__shipping-headline">
            {%- if cart_subtotal >= free_shipping_threshold -%}
              Yayyy!! You have unlocked free shipping
            {%- else -%}
              {%- assign needed_shipping = free_shipping_threshold | minus: cart_subtotal -%}
              Add <strong>{{ needed_shipping | money }}</strong> more to unlock <strong>FREE SHIPPING</strong>
            {%- endif -%}
          </div>
          <div class="cart-drawer__shipping-track-bg">
            <div
              class="cart-drawer__shipping-track-fill"
              style="width: {% if cart_subtotal >= free_shipping_threshold %}100%{% else %}{{ cart_subtotal | times: 100 | divided_by: free_shipping_threshold }}%{% endif %};"
            ></div>
          </div>
        </div>
      {%- endif -%}

      <cart-drawer-items
        {% if cart == empty %}
          class=" is-empty"
        {% endif %}
      >
        <form
          action="{{ routes.cart_url }}"
          id="CartDrawer-Form"
          class="cart__contents cart-drawer__form"
          method="post"
        >
          <div id="CartDrawer-CartItems" class="drawer__contents js-contents">
            {%- if cart != empty -%}
              <div class="cart-drawer__item-list">
                {%- for item in cart.items -%}
                  <div class="cart-drawer__item-row" id="CartDrawer-Item-{{ item.index | plus: 1 }}">
                    <div class="cart-drawer__item-media">
                      {%- if item.image -%}
                        <img
                          src="{{ item.image | image_url: width: 240 }}"
                          alt="{{ item.product.title | escape }}"
                          loading="lazy"
                          width="85"
                          height="110"
                        >
                      {%- endif -%}
                    </div>

                    <div class="cart-drawer__item-details">
                      <a href="{{ item.url }}" class="cart-drawer__item-title">
                        {{ item.product.title | escape }}
                        {%- if item.product.handle == 'velvet-potli' or item.properties._free_gift == 'true' -%}
                          <span class="cart-drawer__gift-pill">FREE GIFT</span>
                        {%- endif -%}
                      </a>

                      {%- if item.product.has_only_default_variant == false -%}
                        <div class="cart-drawer__item-variant-label">
                          {%- for option in item.options_with_values -%}
                            {{ option.name }}: {{ option.value -}}
                            {%- unless forloop.last %}, {% endunless %}
                          {%- endfor -%}
                        </div>
                      {%- endif -%}

                      <div class="cart-drawer__item-bottom-actions">
                        <quantity-popover>
                          <div class="cart-drawer__qty-wrapper">
                            <quantity-input class="quantity cart-quantity cart-drawer__qty-box">
                              <button class="quantity__button" name="minus" type="button" aria-label="Decrease">
                                <svg width="10" height="2" viewBox="0 0 10 2" fill="none"><path d="M0 1h10" stroke="currentColor" stroke-width="1.5"/></svg>
                              </button>
                              <input
                                class="quantity__input"
                                type="number"
                                data-quantity-variant-id="{{ item.variant.id }}"
                                name="updates[]"
                                value="{{ item.quantity }}"
                                min="0"
                                id="Drawer-quantity-{{ item.index | plus: 1 }}"
                                data-index="{{ item.index | plus: 1 }}"
                              >
                              <button class="quantity__button" name="plus" type="button" aria-label="Increase">
                                <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M5 0v10M0 5h10" stroke="currentColor" stroke-width="1.5"/></svg>
                              </button>
                            </quantity-input>

                            <cart-remove-button
                              id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
                              data-index="{{ item.index | plus: 1 }}"
                            >
                              <button
                                type="button"
                                class="cart-drawer__trash-btn"
                                aria-label="Remove item"
                                data-variant-id="{{ item.variant.id }}"
                              >
                                <svg width="16" height="18" viewBox="0 0 24 24" fill="none" stroke="#777777" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                  <path d="M3 6h18"></path>
                                  <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path>
                                  <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path>
                                </svg>
                              </button>
                            </cart-remove-button>
                          </div>
                        </quantity-popover>
                      </div>
                    </div>

                    <div class="cart-drawer__item-price-col">
                      {%- if item.original_line_price != item.final_line_price -%}
                        <s class="cart-drawer__item-old-price">{{ item.original_line_price | money }}</s>
                        <span class="cart-drawer__item-price">{{ item.final_line_price | money }}</span>
                      {%- else -%}
                        <span class="cart-drawer__item-price">{{ item.original_line_price | money }}</span>
                      {%- endif -%}
                    </div>
                  </div>
                {%- endfor -%}
              </div>

              <!-- In-Cart Recommendations Section -->
              {%- assign rec_collection = collections['best-sellers'] -%}
              {%- if rec_collection == blank or rec_collection.products_count == 0 -%}
                {%- assign rec_collection = collections['all'] -%}
              {%- endif -%}

              {%- if rec_collection.products.size > 0 -%}
                <div class="cart-drawer__rec-section">
                  <div class="cart-drawer__rec-header">
                    <h3 class="cart-drawer__rec-heading">Handpicked additions, just for you 🖤</h3>
                    <div class="cart-drawer__rec-arrows">
                      <button type="button" class="cart-drawer__rec-arrow cart-drawer__rec-arrow--prev" aria-label="Previous">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"></polyline></svg>
                      </button>
                      <button type="button" class="cart-drawer__rec-arrow cart-drawer__rec-arrow--next" aria-label="Next">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
                      </button>
                    </div>
                  </div>

                  <div class="cart-drawer__rec-slider">
                    {%- assign rec_added = 0 -%}
                    {%- for rec_prod in rec_collection.products -%}
                      {%- unless rec_prod.available -%}{%- continue -%}{%- endunless -%}
                      {%- assign in_cart = false -%}
                      {%- for ci in cart.items -%}
                        {%- if ci.product_id == rec_prod.id -%}
                          {%- assign in_cart = true -%}
                        {%- endif -%}
                      {%- endfor -%}
                      {%- if in_cart -%}{%- continue -%}{%- endif -%}

                      {%- assign rec_added = rec_added | plus: 1 -%}
                      {%- if rec_added > 8 -%}{%- break -%}{%- endif -%}

                      <div class="cart-rec-item">
                        <div class="cart-rec-item__media">
                          <img src="{{ rec_prod.featured_media | image_url: width: 280 }}" alt="{{ rec_prod.title | escape }}" loading="lazy" width="110" height="145">
                        </div>
                        <div class="cart-rec-item__title">{{ rec_prod.title | escape }}</div>
                        <div class="cart-rec-item__price">{{ rec_prod.price | money }}</div>

                        <div class="cart-rec-item__form">
                          {%- if rec_prod.has_only_default_variant == false -%}
                            <select class="cart-rec-item__select">
                              {%- for variant in rec_prod.variants -%}
                                {%- if variant.available -%}
                                  <option value="{{ variant.id }}">{{ variant.title }}</option>
                                {%- endif -%}
                              {%- endfor -%}
                            </select>
                          {%- else -%}
                            <input type="hidden" class="cart-rec-item__select" value="{{ rec_prod.first_available_variant.id }}">
                          {%- endif -%}

                          <button type="button" class="cart-rec-item__add-btn" data-variant-id="{{ rec_prod.first_available_variant.id }}">
                            ADD
                          </button>
                        </div>
                      </div>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endif -%}
            {%- endif -%}

            <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
            <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">
              {{ 'accessibility.loading' | t }}
            </p>
          </div>
          <div id="CartDrawer-CartErrors" role="alert"></div>
        </form>
      </cart-drawer-items>

      <div class="drawer__footer">
        {%- if cart != empty -%}
          <!-- Multi-Tier Discount Progress Bar -->
          {%- assign start_val = 100000 -%}
          {%- assign tier1_val = 450000 -%}
          {%- assign tier2_val = 700000 -%}
          {%- assign cart_val = cart.total_price -%}

          {%- assign tier_pct = 0 -%}
          {%- if cart_val <= start_val -%}
            {%- assign tier_pct = 0 -%}
          {%- elsif cart_val < tier1_val -%}
            {%- assign range = tier1_val | minus: start_val -%}
            {%- assign current = cart_val | minus: start_val -%}
            {%- assign tier_pct = current | times: 50 | divided_by: range -%}
          {%- elsif cart_val < tier2_val -%}
            {%- assign range = tier2_val | minus: tier1_val -%}
            {%- assign current = cart_val | minus: tier1_val -%}
            {%- assign sub = current | times: 50 | divided_by: range -%}
            {%- assign tier_pct = 50 | plus: sub -%}
          {%- else -%}
            {%- assign tier_pct = 100 -%}
          {%- endif -%}

          <div class="cart-drawer__tier-container">
            <div class="cart-drawer__tier-track-box">
              <!-- Floating Pill -->
              <div class="cart-drawer__tier-floating-pill" style="left: {{ tier_pct }}%;">
                {{ cart_val | money_without_trailing_zeros }}
                <div class="cart-drawer__tier-arrow-down"></div>
              </div>

              <div class="cart-drawer__tier-bar-bg">
                <div class="cart-drawer__tier-bar-fill" style="width: {{ tier_pct }}%;"></div>

                <!-- Node 0 -->
                <div class="cart-drawer__tier-node {% if cart_val >= start_val %}unlocked{% endif %}" style="left: 0%;">
                  <div class="cart-drawer__tier-node-circle">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  </div>
                  <div class="cart-drawer__tier-node-pill">₹1000 Start</div>
                </div>

                <!-- Node 1 -->
                <div class="cart-drawer__tier-node {% if cart_val >= tier1_val %}unlocked{% endif %}" style="left: 50%;">
                  <div class="cart-drawer__tier-node-circle">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg>
                  </div>
                  <div class="cart-drawer__tier-node-label">₹4500 <span>5% OFF</span></div>
                </div>

                <!-- Node 2 -->
                <div class="cart-drawer__tier-node {% if cart_val >= tier2_val %}unlocked{% endif %}" style="left: 100%;">
                  <div class="cart-drawer__tier-node-circle">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                  </div>
                  <div class="cart-drawer__tier-node-label">₹7000 <span>10% OFF</span></div>
                </div>
              </div>
            </div>

            <div class="cart-drawer__tier-message">
              {%- if cart_val < tier1_val -%}
                {%- assign rem = tier1_val | minus: cart_val -%}
                {%- assign disc = tier1_val | times: 5 | divided_by: 100 -%}
                Add items worth <strong>{{ rem | money }}</strong> more & unlock <strong>{{ disc | money }} OFF</strong> instantly!
              {%- elsif cart_val < tier2_val -%}
                {%- assign rem = tier2_val | minus: cart_val -%}
                Add items worth <strong>{{ rem | money }}</strong> more & unlock <strong>10% OFF</strong> instantly!
              {%- else -%}
                🎉 You have unlocked <strong>10% OFF</strong>!
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        <!-- Footer / Subtotal / Checkout Button -->
        <div class="cart-drawer__footer-box">
          <div class="cart-drawer__subtotal-flex">
            <span class="cart-drawer__subtotal-title">Subtotal</span>
            <span class="cart-drawer__subtotal-price">{{ cart.total_price | money }}</span>
          </div>

          <button
            type="submit"
            id="CartDrawer-Checkout"
            class="cart-drawer__checkout-btn"
            name="checkout"
            form="CartDrawer-Form"
            {% if cart == empty %}
              disabled
            {% endif %}
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px; vertical-align:middle;">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
            CHECK OUT
          </button>
        </div>
      </div>
    </div>
  </div>
</cart-drawer>

<script>
  (function() {
    function initCartDrawerRecs() {
      const recTrack = document.querySelector('.cart-drawer__rec-slider');
      const prevBtn = document.querySelector('.cart-drawer__rec-arrow--prev');
      const nextBtn = document.querySelector('.cart-drawer__rec-arrow--next');

      if (recTrack && prevBtn && nextBtn) {
        prevBtn.addEventListener('click', () => {
          recTrack.scrollBy({ left: -180, behavior: 'smooth' });
        });
        nextBtn.addEventListener('click', () => {
          recTrack.scrollBy({ left: 180, behavior: 'smooth' });
        });
      }

      document.querySelectorAll('.cart-rec-item__add-btn').forEach(btn => {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          const card = this.closest('.cart-rec-item');
          const select = card.querySelector('.cart-rec-item__select');
          const variantId = select ? select.value : this.getAttribute('data-variant-id');
          if (!variantId) return;

          this.classList.add('loading');
          this.disabled = true;

          const drawer = document.querySelector('cart-drawer');

          fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify({
              id: variantId,
              quantity: 1,
              sections: drawer ? drawer.getSectionsToRender().map(s => s.section) : ['cart-drawer']
            })
          })
          .then(res => res.json())
          .then(data => {
            if (drawer) {
              drawer.renderContents(data);
              drawer.open();
            } else {
              window.location.reload();
            }
          })
          .catch(err => {
            console.error('Error adding recommendation to cart:', err);
            this.disabled = false;
            this.classList.remove('loading');
          });
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCartDrawerRecs);
    } else {
      initCartDrawerRecs();
    }
  })();
</script>
