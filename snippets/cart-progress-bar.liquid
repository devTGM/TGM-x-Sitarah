{%- comment -%}
  Renders Multi-Tier Cart Progress Bar with Free Gift Auto-Add System
  Milestones:
  - Start: ₹ 0 (0%)
  - Free Shipping: ₹ 4,999 (50%)
  - Free Gift: ₹ 7,999 (100%) - Potli Bags Free Gift (handle: potli-bags-free-gift)
{%- endcomment -%}

{%- liquid
  assign threshold_shipping = 499900
  assign threshold_gift = 799900

  assign free_gift_product = all_products['potli-bags-free-gift']
  assign free_gift_variant_id = free_gift_product.first_available_variant.id

  assign gift_in_cart = false
  assign gift_item_key = ''
  assign cart_total_without_gift = 0

  for item in cart.items
    if item.product.handle == 'potli-bags-free-gift' or item.variant_id == free_gift_variant_id
      assign gift_in_cart = true
      assign gift_item_key = item.key
    else
      assign cart_total_without_gift = cart_total_without_gift | plus: item.final_line_price
    endif
  endfor

  assign cart_total = cart_total_without_gift

  assign is_start_unlocked = false
  assign is_shipping_unlocked = false
  assign is_gift_unlocked = false

  if cart_total > 0
    assign is_start_unlocked = true
  endif

  if cart_total >= threshold_shipping
    assign is_shipping_unlocked = true
  endif

  if cart_total >= threshold_gift
    assign is_gift_unlocked = true
  endif

  # Calculate progress percentage (0% to 100%)
  # 0% to 50% = 0 to threshold_shipping (499900)
  # 50% to 100% = threshold_shipping (499900) to threshold_gift (799900)
  assign progress_percent = 0

  if cart_total <= 0
    assign progress_percent = 0
  elsif cart_total < threshold_shipping
    assign progress_percent = cart_total | times: 50 | divided_by: threshold_shipping
  elsif cart_total < threshold_gift
    assign remaining_range = threshold_gift | minus: threshold_shipping
    assign current_in_range = cart_total | minus: threshold_shipping
    assign range_percent = current_in_range | times: 50 | divided_by: remaining_range
    assign progress_percent = 50 | plus: range_percent
  else
    assign progress_percent = 100
  endif

  if progress_percent > 100
    assign progress_percent = 100
  endif

  if is_gift_unlocked
    assign main_message = "🎉 Congratulations! You unlocked <strong>Free Shipping & Free Gift</strong>!"
  elsif is_shipping_unlocked
    assign amount_to_gift = threshold_gift | minus: cart_total
    assign amount_to_gift_formatted = amount_to_gift | money
    assign main_message = "You are <strong>" | append: amount_to_gift_formatted | append: "</strong> away from <strong>Free Gift</strong>"
  else
    assign amount_to_shipping = threshold_shipping | minus: cart_total
    assign amount_to_shipping_formatted = amount_to_shipping | money
    assign main_message = "You are <strong>" | append: amount_to_shipping_formatted | append: "</strong> away from <strong>Free Shipping</strong>"
  endif
-%}

<cart-progress-bar
  class="cart-progress-container"
  data-is-gift-unlocked="{% if is_gift_unlocked %}true{% else %}false{% endif %}"
  data-is-shipping-unlocked="{% if is_shipping_unlocked %}true{% else %}false{% endif %}"
  data-gift-variant-id="{{ free_gift_variant_id }}"
  data-gift-in-cart="{% if gift_in_cart %}true{% else %}false{% endif %}"
  data-gift-item-key="{{ gift_item_key }}"
  data-cart-non-gift-total="{{ cart_total_without_gift }}"
>
  <!-- Top Banner -->
  <div class="cart-progress__subbanner">
    ✦ FREE SHIPPING ON ORDERS ABOVE ₹4,999 ✦
  </div>

  <!-- Dynamic Message Header -->
  <div class="cart-progress__headline">
    {{ main_message }}
  </div>

  <!-- Multi-Tier Progress Track Widget -->
  <div class="cart-progress__widget">
    <div class="cart-progress__track-wrapper">
      
      <!-- Base Track & Fill -->
      <div class="cart-progress__track">
        <div class="cart-progress__fill" style="width: {{ progress_percent }}%;"></div>
      </div>

      <!-- Node 0: Starting Point at 0% -->
      <div class="cart-progress__milestone cart-progress__milestone--start{% if is_start_unlocked %} is-unlocked{% endif %}">
        <div class="cart-progress__node">
          {%- if is_start_unlocked -%}
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          {%- else -%}
            <span class="cart-progress__dot"></span>
          {%- endif -%}
        </div>
        <div class="cart-progress__badge-bottom">₹0</div>
      </div>

      <!-- Node 1: Free Shipping at 50% -->
      <div class="cart-progress__milestone cart-progress__milestone--shipping{% if is_shipping_unlocked %} is-unlocked{% endif %}">
        <div class="cart-progress__badge-top">FREE SHIPPING</div>
        <div class="cart-progress__node">
          {%- if is_shipping_unlocked -%}
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          {%- else -%}
            <span class="cart-progress__dot"></span>
          {%- endif -%}
        </div>
        <div class="cart-progress__badge-bottom">₹4,999</div>
      </div>

      <!-- Node 2: Free Gift at 100% -->
      <div class="cart-progress__milestone cart-progress__milestone--gift{% if is_gift_unlocked %} is-unlocked{% endif %}">
        <div class="cart-progress__badge-top">FREE GIFT</div>
        <div class="cart-progress__node">
          {%- if is_gift_unlocked -%}
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          {%- else -%}
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 12 20 22 4 22 4 12"></polyline>
              <rect x="2" y="7" width="20" height="5"></rect>
              <line x1="12" y1="22" x2="12" y2="7"></line>
              <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
              <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
            </svg>
          {%- endif -%}
        </div>
        <div class="cart-progress__badge-bottom">₹7,999</div>
      </div>

    </div>
  </div>
</cart-progress-bar>

<script>
  (function() {
    class CartProgressBar extends HTMLElement {
      connectedCallback() {
        const isGiftUnlocked = this.dataset.isGiftUnlocked === 'true';
        const giftInCart = this.dataset.giftInCart === 'true';
        const giftVariantId = this.dataset.giftVariantId;
        const giftItemKey = this.dataset.giftItemKey;
        const nonGiftTotal = parseInt(this.dataset.cartNonGiftTotal || '0', 10);

        // Confetti animation
        if (isGiftUnlocked && !window._sitarahConfettiFired) {
          window._sitarahConfettiFired = true;
          this.triggerConfetti();
        } else if (!isGiftUnlocked) {
          window._sitarahConfettiFired = false;
        }

        // Auto Add Free Gift (Velvet Potli) if non-gift cart total >= ₹ 7,999 (799900 paise)
        if (nonGiftTotal >= 799900 && !giftInCart && giftVariantId && !window._sitarahGiftUpdating) {
          window._sitarahGiftUpdating = true;
          this.addFreeGift(giftVariantId);
        }
        // Auto Remove Free Gift if non-gift cart total drops below ₹ 7,999
        else if (nonGiftTotal < 799900 && giftInCart && !window._sitarahGiftUpdating) {
          window._sitarahGiftUpdating = true;
          this.removeFreeGift(giftItemKey || giftVariantId);
        }
      }

      addFreeGift(variantId) {
        const routes = window.Shopify && window.Shopify.routes ? window.Shopify.routes.root : '/';
        fetch(routes + 'cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            items: [{
              id: variantId,
              quantity: 1,
              properties: { '_free_gift': 'true' }
            }]
          })
        })
        .then(res => res.json())
        .then(() => {
          this.refreshCart();
        })
        .catch(err => {
          console.error('Error adding free gift:', err);
          window._sitarahGiftUpdating = false;
        });
      }

      removeFreeGift(itemKeyOrId) {
        const routes = window.Shopify && window.Shopify.routes ? window.Shopify.routes.root : '/';
        fetch(routes + 'cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            id: itemKeyOrId.toString(),
            quantity: 0
          })
        })
        .then(res => res.json())
        .then(() => {
          this.refreshCart();
        })
        .catch(err => {
          console.error('Error removing free gift:', err);
          window._sitarahGiftUpdating = false;
        });
      }

      refreshCart() {
        const routes = window.Shopify && window.Shopify.routes ? window.Shopify.routes.root : '/';
        fetch(`${routes}cart?sections=cart-drawer,cart-icon-bubble`)
          .then(res => res.json())
          .then(parsedState => {
            window._sitarahGiftUpdating = false;
            const drawer = document.querySelector('cart-drawer');
            if (drawer && typeof drawer.renderContents === 'function') {
              drawer.renderContents(parsedState);
            } else {
              window.location.reload();
            }
          })
          .catch(() => {
            window._sitarahGiftUpdating = false;
            window.location.reload();
          });
      }

      triggerConfetti() {
        const canvas = document.createElement('canvas');
        canvas.style.position = 'fixed';
        canvas.style.top = '0';
        canvas.style.left = '0';
        canvas.style.width = '100vw';
        canvas.style.height = '100vh';
        canvas.style.pointerEvents = 'none';
        canvas.style.zIndex = '9999999';
        document.body.appendChild(canvas);

        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;

        const colors = ['#58021e', '#25D366', '#f8e6eb', '#ffd700', '#ffffff', '#e63946'];
        const particles = [];
        const count = 90;

        for (let i = 0; i < count; i++) {
          particles.push({
            x: canvas.width / 2 + (Math.random() - 0.5) * 300,
            y: canvas.height * 0.25 + (Math.random() - 0.5) * 100,
            vx: (Math.random() - 0.5) * 14,
            vy: (Math.random() - 0.85) * 16,
            size: Math.random() * 9 + 4,
            color: colors[Math.floor(Math.random() * colors.length)],
            rotation: Math.random() * 360,
            rSpeed: (Math.random() - 0.5) * 12,
            opacity: 1
          });
        }

        const startTime = Date.now();
        function animate() {
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          const elapsed = Date.now() - startTime;

          particles.forEach((p) => {
            p.x += p.vx;
            p.y += p.vy;
            p.vy += 0.38;
            p.rotation += p.rSpeed;
            if (elapsed > 1800) {
              p.opacity -= 0.035;
            }

            if (p.opacity > 0) {
              ctx.save();
              ctx.translate(p.x, p.y);
              ctx.rotate((p.rotation * Math.PI) / 180);
              ctx.globalAlpha = Math.max(0, p.opacity);
              ctx.fillStyle = p.color;
              ctx.fillRect(-p.size / 2, -p.size / 2, p.size, p.size * 1.4);
              ctx.restore();
            }
          });

          if (elapsed < 3000) {
            requestAnimationFrame(animate);
          } else {
            if (canvas.parentNode) canvas.parentNode.removeChild(canvas);
          }
        }

        requestAnimationFrame(animate);
      }
    }

    if (!customElements.get('cart-progress-bar')) {
      customElements.define('cart-progress-bar', CartProgressBar);
    }
  })();
</script>
