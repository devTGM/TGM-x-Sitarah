{%- comment -%}
  ============================================================
  Slideshow – Sitarah Hero Banner
  ● Transparent header (absolute overlay)
  ● Separate Desktop / Mobile image pickers per slide
  ● Mobile fallback → optimised desktop image via srcset
  ● Video slide (native Shopify .mp4 upload)
  ● Auto-rotation with progress bar + pause/play
  ● Up to 10 slides  |  Swipe + Keyboard nav
  ============================================================
{%- endcomment -%}

{%- style -%}
/* ════════════════════════════════════════════════════════════
   TRANSPARENT HEADER – ALL ELEMENTS including submenu triggers
   ════════════════════════════════════════════════════════════ */
.slideshow-transparent-header .section-header {
  position: absolute;
  top: 0; left: 0; right: 0;
  width: 100%;
  z-index: 100;
  background: transparent !important;
  border-bottom: none !important;
  margin-bottom: 0 !important;
  height: auto;
}
.slideshow-transparent-header .header-wrapper {
  background: transparent !important;
  border-bottom: none !important;
  box-shadow: none !important;
}

/* ── Regular nav links (no submenu) ── */
.slideshow-transparent-header .header__heading-link,
.slideshow-transparent-header .header__heading-link span,
.slideshow-transparent-header .header__heading-link .h2,
.slideshow-transparent-header .header__icon,
.slideshow-transparent-header .header__active-menu-item,
.slideshow-transparent-header .list-menu__item--link,
.slideshow-transparent-header .link--text,
.slideshow-transparent-header nav a,
.slideshow-transparent-header .header__inline-menu a {
  color: {{ section.settings.transparent_header_color }} !important;
}

/* ── Submenu triggers: <details> > <summary> (e.g. COLLECTIONS, CATEGORIES, OCCASION)
      Use html. prefix for maximum specificity to beat theme color-scheme overrides ── */
html.slideshow-transparent-header .header__menu-item,
html.slideshow-transparent-header summary.header__menu-item,
html.slideshow-transparent-header summary.list-menu__item,
html.slideshow-transparent-header details > summary,
html.slideshow-transparent-header details > summary > span,
html.slideshow-transparent-header header-menu > details > summary,
html.slideshow-transparent-header header-menu > details > summary > span,
html.slideshow-transparent-header .header__inline-menu details > summary,
html.slideshow-transparent-header .header__inline-menu details > summary > span,
html.slideshow-transparent-header .header__inline-menu details > summary .header__active-menu-item,
html.slideshow-transparent-header .mega-menu details > summary,
html.slideshow-transparent-header .mega-menu details > summary > span {
  color: {{ section.settings.transparent_header_color }} !important;
}

/* ── ALL SVG icons: cart, search, account + caret arrows on submenu items ── */
.slideshow-transparent-header .header__icon svg path,
.slideshow-transparent-header .header__icon svg circle,
.slideshow-transparent-header .header__icon svg polyline,
.slideshow-transparent-header .header__icon svg rect,
.slideshow-transparent-header .header__icon svg line,
.slideshow-transparent-header .header__inline-menu svg path,
.slideshow-transparent-header .header__inline-menu svg polyline,
.slideshow-transparent-header .header__inline-menu svg line,
html.slideshow-transparent-header header-menu svg path,
html.slideshow-transparent-header header-menu svg polyline,
html.slideshow-transparent-header details > summary svg path,
html.slideshow-transparent-header details > summary svg polyline,
.slideshow-transparent-header .icon-caret {
  stroke: {{ section.settings.transparent_header_color }} !important;
  fill: none !important;
}

/* ── Cart count bubble ── */
.slideshow-transparent-header .cart-count-bubble {
  background: {{ section.settings.transparent_header_color }} !important;
  color: #000 !important;
}

/* ── Logo filter ── */
.slideshow-transparent-header .header__heading-logo {
  filter: {{ section.settings.logo_filter }};
}

/* ════════════════════════════════════════════════════════════
   BANNER WRAPPER
   ════════════════════════════════════════════════════════════ */
.sitarah-slideshow {
  position: relative;
  width: 100%;
  /* Prevent the section from adding extra space below */
  display: block;
  overflow: hidden;
  background: #000;
  /* Use svh for mobile browsers that include the browser chrome in vh */
  height: {{ section.settings.height_desktop }}vh;
  height: {{ section.settings.height_desktop }}svh;
}
@media screen and (max-width: 749px) {
  .sitarah-slideshow {
    height: {{ section.settings.height_mobile }}vh;
    height: {{ section.settings.height_mobile }}svh;
  }
}
/* Ensure the Shopify section wrapper itself has no margin/padding */
.sitarah-slideshow-section,
.section.sitarah-slideshow-section {
  margin: 0 !important;
  padding: 0 !important;
}

/* ── Track ── */
.sitarah-slideshow__track {
  display: flex;
  height: 100%;
  transition: transform 0.9s cubic-bezier(0.77, 0, 0.18, 1);
  will-change: transform;
}

/* ── Slide ── */
.sitarah-slideshow__slide {
  position: relative;
  min-width: 100%;
  flex: 0 0 100%;
  height: 100%;
  overflow: hidden;
}

/* ── Media ── */
.sitarah-slideshow__media {
  position: absolute;
  inset: 0;
  width: 100%; height: 100%;
}
.sitarah-slideshow__media img,
.sitarah-slideshow__media video {
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}
/* Mobile / Desktop image swap */
.sitarah-slideshow__img--mobile { display: none; }
@media screen and (max-width: 749px) {
  .sitarah-slideshow__img--desktop { display: none; }
  .sitarah-slideshow__img--mobile  { display: block; }
}

/* ── Overlay ── */
.sitarah-slideshow__overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
}

/* ── Content ── */
.sitarah-slideshow__content {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  flex-direction: column;
  /* Top padding accounts for header height so content is never hidden behind it.
     80px is a safe default; Shopify sets --header-height via JS for sticky headers. */
  padding: max(80px, calc(var(--header-height, 80px) + 1rem)) max(3rem, calc((100vw - 1400px) / 2 + 3rem)) 3rem;
  overflow: hidden;
  box-sizing: border-box;
}
.sitarah-slideshow__content--top-left    { align-items: flex-start; justify-content: flex-start; text-align: left; }
.sitarah-slideshow__content--top-center  { align-items: center;     justify-content: flex-start; text-align: center; }
.sitarah-slideshow__content--top-right   { align-items: flex-end;   justify-content: flex-start; text-align: right; }
.sitarah-slideshow__content--middle-left   { align-items: flex-start; justify-content: center; text-align: left; }
.sitarah-slideshow__content--middle-center { align-items: center;     justify-content: center; text-align: center; }
.sitarah-slideshow__content--middle-right  { align-items: flex-end;   justify-content: center; text-align: right; }
.sitarah-slideshow__content--bottom-left   { align-items: flex-start; justify-content: flex-end; text-align: left; }
.sitarah-slideshow__content--bottom-center { align-items: center;     justify-content: flex-end; text-align: center; }
.sitarah-slideshow__content--bottom-right  { align-items: flex-end;   justify-content: flex-end; text-align: right; }

@media screen and (max-width: 749px) {
  .sitarah-slideshow__content {
    align-items: center !important;
    justify-content: flex-end !important;
    text-align: center !important;
    padding: max(70px, calc(var(--header-height, 70px) + 0.5rem)) 1.25rem 5rem;
  }
}

/* ── Text elements ── */
.sitarah-slideshow__eyebrow {
  font-size: 0.72rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  margin: 0 0 0.65rem;
  opacity: 0;
  transform: translateY(18px);
  transition: opacity 0.55s 0.15s ease, transform 0.55s 0.15s ease;
}
.sitarah-slideshow__heading {
  font-size: clamp(1.8rem, 4.5vw, 4rem);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin: 0 0 0.9rem;
  max-width: 18ch;
  opacity: 0;
  transform: translateY(22px);
  transition: opacity 0.65s 0.3s ease, transform 0.65s 0.3s ease;
}
.sitarah-slideshow__heading p { margin: 0; }
.sitarah-slideshow__subheading {
  font-size: clamp(0.9rem, 1.4vw, 1.1rem);
  line-height: 1.65;
  margin: 0 0 1.75rem;
  max-width: 48ch;
  opacity: 0;
  transform: translateY(18px);
  transition: opacity 0.55s 0.45s ease, transform 0.55s 0.45s ease;
}
.sitarah-slideshow__buttons {
  display: flex;
  gap: 0.85rem;
  flex-wrap: wrap;
  opacity: 0;
  transform: translateY(18px);
  transition: opacity 0.55s 0.6s ease, transform 0.55s 0.6s ease;
}
@media screen and (max-width: 749px) {
  .sitarah-slideshow__heading { max-width: 100%; }
  .sitarah-slideshow__subheading { max-width: 100%; }
  .sitarah-slideshow__buttons { justify-content: center; }
}

/* Animate in when active */
.sitarah-slideshow__slide--active .sitarah-slideshow__eyebrow,
.sitarah-slideshow__slide--active .sitarah-slideshow__heading,
.sitarah-slideshow__slide--active .sitarah-slideshow__subheading,
.sitarah-slideshow__slide--active .sitarah-slideshow__buttons {
  opacity: 1;
  transform: translateY(0);
}

/* ── Buttons ── */
.sitarah-slideshow__btn {
  display: inline-flex;
  align-items: center;
  padding: 0.8rem 1.9rem;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  text-decoration: none;
  border: 2px solid transparent;
  cursor: pointer;
  transition: background 0.3s, color 0.3s, border-color 0.3s, transform 0.2s;
}
.sitarah-slideshow__btn:hover { transform: translateY(-2px); }
.sitarah-slideshow__btn--primary {
  background: #fff; color: #111; border-color: #fff;
}
.sitarah-slideshow__btn--primary:hover {
  background: transparent; color: #fff;
}
.sitarah-slideshow__btn--secondary {
  background: transparent; color: #fff; border-color: rgba(255,255,255,0.65);
}
.sitarah-slideshow__btn--secondary:hover {
  background: rgba(255,255,255,0.12); border-color: #fff;
}

/* ── Arrow controls ── */
.sitarah-slideshow__arrow {
  position: absolute;
  top: 50%; transform: translateY(-50%);
  z-index: 10;
  width: 48px; height: 48px;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,0.12);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255,255,255,0.25);
  border-radius: 50%;
  color: #fff;
  cursor: pointer;
  padding: 0;
  transition: background 0.3s, transform 0.25s;
}
.sitarah-slideshow__arrow:hover {
  background: rgba(255,255,255,0.26);
  transform: translateY(-50%) scale(1.08);
}
.sitarah-slideshow__arrow svg { width: 20px; height: 20px; }
.sitarah-slideshow__arrow--prev { left: 1.25rem; }
.sitarah-slideshow__arrow--next { right: 1.25rem; }
@media screen and (max-width: 749px) {
  .sitarah-slideshow__arrow { width: 38px; height: 38px; }
  .sitarah-slideshow__arrow svg { width: 16px; height: 16px; }
  .sitarah-slideshow__arrow--prev { left: 0.6rem; }
  .sitarah-slideshow__arrow--next { right: 0.6rem; }
}

/* ── Dot nav ── */
.sitarah-slideshow__dots {
  position: absolute;
  bottom: 1.6rem; left: 50%;
  transform: translateX(-50%);
  z-index: 10;
  display: flex;
  gap: 0.45rem;
  align-items: center;
}
.sitarah-slideshow__dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: rgba(255,255,255,0.38);
  border: none; padding: 0; cursor: pointer;
  flex-shrink: 0;
  transition: background 0.3s, width 0.4s cubic-bezier(0.34,1.56,0.64,1), border-radius 0.4s;
}
.sitarah-slideshow__dot--active {
  background: #fff;
  width: 26px;
  border-radius: 4px;
}

/* ── Progress bar ── */
.sitarah-slideshow__progress {
  position: absolute;
  bottom: 0; left: 0;
  width: 100%; height: 2px;
  background: rgba(255,255,255,0.2);
  z-index: 10;
  overflow: hidden;
}
.sitarah-slideshow__progress-fill {
  height: 100%;
  width: 0%;
  background: rgba(255,255,255,0.82);
  transition: width linear;
}

/* ── Pause button ── */
.sitarah-slideshow__pause {
  position: absolute;
  bottom: 1.3rem; right: 1.3rem;
  z-index: 10;
  width: 34px; height: 34px;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.28);
  background: rgba(255,255,255,0.1);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  color: #fff;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  padding: 0;
  transition: background 0.3s;
}
.sitarah-slideshow__pause:hover { background: rgba(255,255,255,0.24); }
.sitarah-slideshow__pause svg { width: 13px; height: 13px; }
.sitarah-slideshow__pause .icon-play-ss { display: none; }
.sitarah-slideshow__pause.is-paused .icon-pause-ss { display: none; }
.sitarah-slideshow__pause.is-paused .icon-play-ss  { display: block; }

/* hide controls when only 1 slide */
{% if section.blocks.size < 2 %}
.sitarah-slideshow__arrow,
.sitarah-slideshow__dots,
.sitarah-slideshow__progress,
.sitarah-slideshow__pause { display: none !important; }
{% endif %}
{%- endstyle -%}

{%- if section.settings.transparent_header -%}
  <script>document.documentElement.classList.add('slideshow-transparent-header');</script>
{%- endif -%}

<div
  class="sitarah-slideshow"
  id="SitarahSS-{{ section.id }}"
  data-autoplay="{{ section.settings.auto_rotate }}"
  data-speed="{{ section.settings.change_slides_speed | times: 1000 }}"
  role="region"
  aria-label="{{ section.settings.accessibility_info | default: 'Slideshow' | escape }}"
>

  {%- comment -%}── Track ──{%- endcomment -%}
  <div class="sitarah-slideshow__track" id="SitarahSSTrack-{{ section.id }}">

    {%- for block in section.blocks -%}
      <div
        class="sitarah-slideshow__slide{% if forloop.first %} sitarah-slideshow__slide--active{% endif %}"
        id="SitarahSSSlide-{{ section.id }}-{{ forloop.index }}"
        {{ block.shopify_attributes }}
        role="group"
        aria-roledescription="slide"
        aria-label="{{ forloop.index }} of {{ forloop.length }}"
      >

        {%- comment -%}──── MEDIA ────{%- endcomment -%}
        <div class="sitarah-slideshow__media">
          {%- if block.type == 'video_slide' -%}
            {%- if block.settings.video != blank -%}
              {{
                block.settings.video
                | video_tag:
                  autoplay: true,
                  loop: true,
                  muted: true,
                  playsinline: true
              }}
            {%- else -%}
              {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}

          {%- else -%}
            {%- assign dimg = block.settings.desktop_image -%}
            {%- assign mimg = block.settings.mobile_image -%}

            {%- if dimg != blank -%}
              {%- comment -%} Desktop image {%- endcomment -%}
              <img
                class="sitarah-slideshow__img--desktop"
                src="{{ dimg | image_url: width: 2000 }}"
                srcset="
                  {{ dimg | image_url: width: 750 }} 750w,
                  {{ dimg | image_url: width: 1100 }} 1100w,
                  {{ dimg | image_url: width: 1500 }} 1500w,
                  {{ dimg | image_url: width: 2000 }} 2000w,
                  {{ dimg | image_url: width: 3000 }} 3000w
                "
                sizes="100vw"
                alt="{{ dimg.alt | escape | default: block.settings.heading }}"
                width="{{ dimg.width }}"
                height="{{ dimg.height }}"
                {% if forloop.first %}fetchpriority="high"{% else %}loading="lazy"{% endif %}
              >

              {%- comment -%} Mobile image (dedicated or fallback) {%- endcomment -%}
              {%- if mimg != blank -%}
                <img
                  class="sitarah-slideshow__img--mobile"
                  src="{{ mimg | image_url: width: 750 }}"
                  srcset="
                    {{ mimg | image_url: width: 375 }} 375w,
                    {{ mimg | image_url: width: 550 }} 550w,
                    {{ mimg | image_url: width: 750 }} 750w
                  "
                  sizes="100vw"
                  alt="{{ mimg.alt | escape | default: block.settings.heading }}"
                  width="{{ mimg.width }}"
                  height="{{ mimg.height }}"
                  {% if forloop.first %}fetchpriority="high"{% else %}loading="lazy"{% endif %}
                >
              {%- else -%}
                {%- comment -%} Optimised desktop image served to mobile {%- endcomment -%}
                <img
                  class="sitarah-slideshow__img--mobile"
                  src="{{ dimg | image_url: width: 750 }}"
                  srcset="
                    {{ dimg | image_url: width: 375 }} 375w,
                    {{ dimg | image_url: width: 550 }} 550w,
                    {{ dimg | image_url: width: 750 }} 750w
                  "
                  sizes="100vw"
                  alt="{{ dimg.alt | escape | default: block.settings.heading }}"
                  width="{{ dimg.width }}"
                  height="{{ dimg.height }}"
                  {% if forloop.first %}fetchpriority="high"{% else %}loading="lazy"{% endif %}
                >
              {%- endif -%}
            {%- else -%}
              {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          {%- endif -%}
        </div>

        {%- comment -%}──── OVERLAY ────{%- endcomment -%}
        <div
          class="sitarah-slideshow__overlay"
          style="background: {{ block.settings.overlay_color }}; opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"
        ></div>

        {%- comment -%}──── CONTENT ────{%- endcomment -%}
        <div class="sitarah-slideshow__content sitarah-slideshow__content--{{ block.settings.box_align }}">

          {%- if block.settings.eyebrow != blank -%}
            <p class="sitarah-slideshow__eyebrow" style="color: {{ block.settings.text_color }};">
              {{ block.settings.eyebrow | escape }}
            </p>
          {%- endif -%}

          {%- if block.settings.heading != blank -%}
            {%- if forloop.first and request.page_type == 'index' -%}
              <h1 class="sitarah-slideshow__heading" style="color: {{ block.settings.text_color }};">
                {{ block.settings.heading }}
              </h1>
            {%- else -%}
              <h2 class="sitarah-slideshow__heading" style="color: {{ block.settings.text_color }};">
                {{ block.settings.heading }}
              </h2>
            {%- endif -%}
          {%- endif -%}

          {%- if block.settings.subheading != blank -%}
            <p class="sitarah-slideshow__subheading" style="color: {{ block.settings.text_color }};">
              {{ block.settings.subheading | escape }}
            </p>
          {%- endif -%}

          {%- if block.settings.button_1_label != blank or block.settings.button_2_label != blank -%}
            <div class="sitarah-slideshow__buttons">
              {%- if block.settings.button_1_label != blank -%}
                <a
                  href="{{ block.settings.button_1_link | default: '#' }}"
                  class="sitarah-slideshow__btn sitarah-slideshow__btn--primary"
                >{{ block.settings.button_1_label | escape }}</a>
              {%- endif -%}
              {%- if block.settings.button_2_label != blank -%}
                <a
                  href="{{ block.settings.button_2_link | default: '#' }}"
                  class="sitarah-slideshow__btn sitarah-slideshow__btn--secondary"
                >{{ block.settings.button_2_label | escape }}</a>
              {%- endif -%}
            </div>
          {%- endif -%}

        </div>
      </div>
    {%- endfor -%}

  </div>{%- comment -%}/.track{%- endcomment -%}

  {%- if section.blocks.size > 1 -%}

    {%- comment -%}── Arrows ──{%- endcomment -%}
    <button class="sitarah-slideshow__arrow sitarah-slideshow__arrow--prev" aria-label="Previous slide" data-ss-prev>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="sitarah-slideshow__arrow sitarah-slideshow__arrow--next" aria-label="Next slide" data-ss-next>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>

    {%- comment -%}── Dots ──{%- endcomment -%}
    <div class="sitarah-slideshow__dots" role="tablist" aria-label="Slides">
      {%- for block in section.blocks -%}
        <button
          class="sitarah-slideshow__dot{% if forloop.first %} sitarah-slideshow__dot--active{% endif %}"
          data-ss-dot="{{ forloop.index0 }}"
          role="tab"
          aria-selected="{{ forloop.first }}"
          aria-label="Go to slide {{ forloop.index }}"
        ></button>
      {%- endfor -%}
    </div>

    {%- comment -%}── Progress bar ──{%- endcomment -%}
    {%- if section.settings.auto_rotate -%}
      <div class="sitarah-slideshow__progress" aria-hidden="true">
        <div class="sitarah-slideshow__progress-fill" id="SitarahSSProg-{{ section.id }}"></div>
      </div>

      {%- comment -%}── Pause / Play ──{%- endcomment -%}
      <button class="sitarah-slideshow__pause" aria-label="Pause slideshow" data-ss-pause>
        <svg class="icon-pause-ss" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/></svg>
        <svg class="icon-play-ss"  viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      </button>
    {%- endif -%}

  {%- endif -%}

</div>

{%- if request.design_mode -%}
  <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<script>
(function () {
  'use strict';
  const wrap = document.getElementById('SitarahSS-{{ section.id }}');
  if (!wrap) return;

  const track    = wrap.querySelector('.sitarah-slideshow__track');
  const slides   = Array.from(wrap.querySelectorAll('.sitarah-slideshow__slide'));
  const dots     = Array.from(wrap.querySelectorAll('[data-ss-dot]'));
  const prevBtn  = wrap.querySelector('[data-ss-prev]');
  const nextBtn  = wrap.querySelector('[data-ss-next]');
  const pauseBtn = wrap.querySelector('[data-ss-pause]');
  const progFill = wrap.querySelector('.sitarah-slideshow__progress-fill');

  const total    = slides.length;
  const autoplay = wrap.dataset.autoplay === 'true';
  const speed    = parseInt(wrap.dataset.speed, 10) || 5000;

  let current = 0;
  let timer   = null;
  let paused  = false;

  /* ─── Core go-to ─── */
  function goTo(idx) {
    idx = ((idx % total) + total) % total;
    slides[current].classList.remove('sitarah-slideshow__slide--active');
    dots[current]?.classList.remove('sitarah-slideshow__dot--active');
    dots[current]?.setAttribute('aria-selected', 'false');

    current = idx;
    track.style.transform = `translateX(-${current * 100}%)`;

    slides[current].classList.add('sitarah-slideshow__slide--active');
    dots[current]?.classList.add('sitarah-slideshow__dot--active');
    dots[current]?.setAttribute('aria-selected', 'true');

    if (autoplay && !paused) startProgress();
  }

  const next = () => goTo(current + 1);
  const prev = () => goTo(current - 1);

  /* ─── Timer ─── */
  function startTimer() {
    clearInterval(timer);
    if (!autoplay || paused) return;
    timer = setInterval(next, speed);
  }
  function stopTimer() { clearInterval(timer); }

  /* ─── Progress bar ─── */
  function startProgress() {
    if (!progFill) return;
    progFill.style.transition = 'none';
    progFill.style.width = '0%';
    void progFill.offsetWidth; // reflow
    progFill.style.transition = `width ${speed}ms linear`;
    progFill.style.width = '100%';
  }
  function freezeProgress() {
    if (!progFill) return;
    const pct = (parseFloat(getComputedStyle(progFill).width) / progFill.parentElement.offsetWidth) * 100;
    progFill.style.transition = 'none';
    progFill.style.width = pct + '%';
  }

  /* ─── Init ─── */
  if (autoplay && total > 1) { startTimer(); startProgress(); }

  /* ─── Hover pause ─── */
  wrap.addEventListener('mouseenter', () => { if (autoplay) { stopTimer(); freezeProgress(); } });
  wrap.addEventListener('mouseleave', () => { if (autoplay && !paused) { startTimer(); startProgress(); } });

  /* ─── Controls ─── */
  prevBtn?.addEventListener('click', () => { stopTimer(); prev(); startTimer(); });
  nextBtn?.addEventListener('click', () => { stopTimer(); next(); startTimer(); });

  dots.forEach(d => d.addEventListener('click', () => {
    stopTimer(); goTo(parseInt(d.dataset.ssDot, 10)); startTimer();
  }));

  pauseBtn?.addEventListener('click', () => {
    paused = !paused;
    pauseBtn.classList.toggle('is-paused', paused);
    pauseBtn.setAttribute('aria-label', paused ? 'Play slideshow' : 'Pause slideshow');
    paused ? (stopTimer(), freezeProgress()) : (startTimer(), startProgress());
  });

  /* ─── Touch swipe ─── */
  let sx = 0;
  wrap.addEventListener('touchstart', e => { sx = e.changedTouches[0].screenX; }, { passive: true });
  wrap.addEventListener('touchend', e => {
    const dx = sx - e.changedTouches[0].screenX;
    if (Math.abs(dx) > 50) { stopTimer(); dx > 0 ? next() : prev(); startTimer(); }
  }, { passive: true });

  /* ─── Keyboard ─── */
  wrap.setAttribute('tabindex', '0');
  wrap.addEventListener('keydown', e => {
    if (e.key === 'ArrowLeft')  { stopTimer(); prev(); startTimer(); }
    if (e.key === 'ArrowRight') { stopTimer(); next(); startTimer(); }
  });

  /* ─── Shopify theme editor ─── */
  document.addEventListener('shopify:block:select', e => {
    const s = e.target.closest('.sitarah-slideshow__slide');
    if (!s) return;
    const i = slides.indexOf(s);
    if (i > -1) { stopTimer(); goTo(i); }
  });
  document.addEventListener('shopify:block:deselect', () => {
    if (autoplay && !paused) startTimer();
  });
})();
</script>

