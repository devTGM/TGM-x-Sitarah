{%- comment -%}
  Categories Section - Placed below Hero Banner with Desktop Arrow Controls & Drag/Wheel Scroll
{%- endcomment -%}

{{ 'section-categories-cards.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: {{ section.settings.padding_side_mobile }}px;
    padding-right: {{ section.settings.padding_side_mobile }}px;
    --cat-title-size: {{ section.settings.title_font_size }}px;
    --cat-title-weight: {{ section.settings.title_font_weight }};
    --cat-title-transform: {{ section.settings.title_transform }};
    --cat-title-color: {{ section.settings.title_color }};
    --cat-title-hover-color: {{ section.settings.title_hover_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      padding-left: {{ section.settings.padding_side }}px;
      padding-right: {{ section.settings.padding_side }}px;
    }
  }
{%- endstyle -%}

<div class="categories-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    <categories-slider class="categories-slider-wrapper">
      {%- if section.settings.title != blank -%}
        <div class="categories-section__heading-wrapper text-{{ section.settings.heading_alignment }}">
          <h2 class="categories-section__heading inline-richtext {{ section.settings.heading_size }}">
            {{ section.settings.title }}
          </h2>
        </div>
      {%- endif -%}

      <div class="categories-grid categories-grid--{{ section.settings.columns_desktop }}-col">
        {%- for block in section.blocks -%}
          <div class="category-card" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link | default: '#' }}" class="category-card__link">
              <div class="category-card__image-wrapper">
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 800 }}"
                    alt="{{ block.settings.title | strip_html | escape }}"
                    loading="lazy"
                    width="800"
                    height="1066"
                    class="category-card__image"
                  >
                {%- elsif block.settings.collection != blank and block.settings.collection.featured_image != blank -%}
                  <img
                    src="{{ block.settings.collection.featured_image | image_url: width: 800 }}"
                    alt="{{ block.settings.title | default: block.settings.collection.title | strip_html | escape }}"
                    loading="lazy"
                    width="800"
                    height="1066"
                    class="category-card__image"
                  >
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'category-card__image category-card__placeholder' }}
                {%- endif -%}
              </div>
              {%- assign card_title = block.settings.title -%}
              {%- if card_title == blank and block.settings.collection != blank -%}
                {%- assign card_title = block.settings.collection.title -%}
              {%- endif -%}
              {%- if card_title != blank -%}
                <h3 class="category-card__title inline-richtext">
                  {{ card_title }}
                </h3>
              {%- endif -%}
            </a>
          </div>
        {%- endfor -%}
      </div>
    </categories-slider>
  </div>
</div>

<script>
  (function() {
    class CategoriesSlider extends HTMLElement {
      connectedCallback() {
        this.grid = this.querySelector('.categories-grid');
        this.prevBtn = this.querySelector('.categories-slider__arrow--prev');
        this.nextBtn = this.querySelector('.categories-slider__arrow--next');

        if (!this.grid) return;

        if (this.prevBtn) {
          this.prevBtn.addEventListener('click', () => {
            const scrollAmount = this.grid.clientWidth * 0.75;
            this.grid.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
          });
        }

        if (this.nextBtn) {
          this.nextBtn.addEventListener('click', () => {
            const scrollAmount = this.grid.clientWidth * 0.75;
            this.grid.scrollBy({ left: scrollAmount, behavior: 'smooth' });
          });
        }

        // Mouse Drag to Scroll on Desktop
        let isDown = false;
        let startX;
        let scrollLeft;

        this.grid.addEventListener('mousedown', (e) => {
          isDown = true;
          this.grid.classList.add('is-dragging');
          startX = e.pageX - this.grid.offsetLeft;
          scrollLeft = this.grid.scrollLeft;
        });

        this.grid.addEventListener('mouseleave', () => {
          isDown = false;
          this.grid.classList.remove('is-dragging');
        });

        this.grid.addEventListener('mouseup', () => {
          isDown = false;
          this.grid.classList.remove('is-dragging');
        });

        this.grid.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - this.grid.offsetLeft;
          const walk = (x - startX) * 2;
          this.grid.scrollLeft = scrollLeft - walk;
        });

        // Mouse Wheel horizontal scroll assist
        this.grid.addEventListener('wheel', (e) => {
          if (e.deltaY !== 0) {
            const maxScroll = this.grid.scrollWidth - this.grid.clientWidth;
            if (
              (e.deltaY > 0 && this.grid.scrollLeft < maxScroll - 5) ||
              (e.deltaY < 0 && this.grid.scrollLeft > 5)
            ) {
              e.preventDefault();
              this.grid.scrollLeft += e.deltaY * 1.5;
            }
          }
        }, { passive: false });
      }
    }

    if (!customElements.get('categories-slider')) {
      customElements.define('categories-slider', CategoriesSlider);
    }
  })();
</script>

{% schema %}
{
  "name": "Categories Cards",
  "tag": "section",
  "class": "section-categories-cards",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Categories",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left",
      "label": "Heading alignment"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Number of columns visible per view"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Category Title Typography"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Category Title Font Size",
      "default": 18
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "options": [
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi Bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra Bold (800)" }
      ],
      "default": "700",
      "label": "Category Title Font Weight"
    },
    {
      "type": "select",
      "id": "title_transform",
      "options": [
        { "value": "uppercase", "label": "Uppercase (ALL CAPS)" },
        { "value": "capitalize", "label": "Capitalize" },
        { "value": "lowercase", "label": "Lowercase" },
        { "value": "none", "label": "Normal Case (As Typed)" }
      ],
      "default": "uppercase",
      "label": "Category Text Case Format"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Category Title Color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "title_hover_color",
      "label": "Category Title Hover Color",
      "default": "#58021e"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_side",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Left & Right Padding (Desktop)",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_side_mobile",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Left & Right Padding (Mobile)",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Category Image"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "Category Title (Supports Formatting & Bold/Italic)",
          "info": "Use formatting toolbar in theme customizer to style title text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categories Cards",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "KURTA SETS",
            "link": "/collections/kurta-sets"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "CO-ORD SETS",
            "link": "/collections/co-ord-sets"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "FARSHI SALWAR SETS",
            "link": "/collections/farshi-salwar-sets"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "ANARKALI SETS",
            "link": "/collections/anarkali"
          }
        }
      ]
    }
  ]
}
{% endschema %}
